{
  "@context": {
    "@version": 1.1,
    "ow": "https://openwhisk.apache.org/schema/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "KeyValue": "ow:KeyValue",
    "ActionExec": "ow:ActionExec",
    "Action": "ow:Action",
    "ActionRequest": "ow:ActionRequest",
    "ActionLimits": "ow:ActionLimits",
    "Trigger": "ow:Trigger",
