        "application error",
        "developer error",
        "whisk internal error"
      ]
    },
    "statusCode": {
      "type": "int32",
      "description": "HTTP status code equivalent",
      "example": 0
    },
    "success": {
      "type": "boolean",
      "example": true
    },
    "result": {
      "type": "object",
      "description": "Action result payload"
    }
  },
  "name": "ActivationResponse"
}